# --- SharePoint target ---
SP_SITE_URL=https://www.molecule.co.il/legacy-deployed/max-app
SP_LIST_NAME=רשימת בסיס

# Optional: hardcode the list entity type to skip the metadata lookup
# SP_ITEM_TYPE=SP.Data.ListNameListItem

# --- Option A: NTLM service account (preferred) ---
# SP_USERNAME=svc_account
# SP_PASSWORD=super-secret
# SP_DOMAIN=ARMY
# SP_WORKSTATION=

# --- Option B: reuse captured auth cookies (zero dependencies) ---
# Paste the full Cookie header from an authenticated browser session.
# SP_COOKIE=FedAuth=...; rtFa=...

# --- Server ---
PORT=3000
CORS_ORIGIN=*

# Set to 1 only for internal/self-signed TLS (e.g. on-prem CA)
SP_INSECURE_TLS=0
